# Environment variables for dev deployment
# Teams Toolkit will fill in BOT_ID and SECRET_BOT_PASSWORD during provision
TEAMSFX_ENV=dev
BOT_ID=
SECRET_BOT_PASSWORD=
TEAMS_APP_ID=

# Azure subscription (Teams Toolkit will prompt for these via browser login)
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP_NAME=rg-qqia-agent
