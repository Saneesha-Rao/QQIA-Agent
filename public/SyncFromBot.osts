async function main(workbook: ExcelScript.Workbook) {
  // QQIA Agent Sync Script
  // Pulls latest status data from the bot and updates this Excel file
  var botUrl = "https://qqia-agent-462aq56aadxf2.azurewebsites.net/api/steps/json";
  var accessCode = ""; // Set your team access code here if configured

  var fetchUrl = botUrl + (accessCode ? "?code=" + accessCode : "");
  var response: Response;
  try {
    response = await fetch(fetchUrl);
  } catch (err) {
    console.log("Cannot reach the bot. Make sure the Azure App Service is running.");
    return;
  }
  if (!response.ok) {
    console.log("Bot returned error: " + response.status);
    return;
  }
  var data = await response.json() as BotData;
  console.log("Fetched " + data.stepCount + " steps from bot");

  // Find the FY27_Rollover sheet
  var allSheets = workbook.getWorksheets();
  var sheet: ExcelScript.Worksheet | null = null;

  for (var i = 0; i < allSheets.length; i++) {
    if (allSheets[i].getName() === "FY27_Rollover") {
      sheet = allSheets[i];
      break;
    }
  }

  if (!sheet) {
    for (var i = 0; i < allSheets.length; i++) {
      var name = allSheets[i].getName().toLowerCase();
      if (name.indexOf("rollover") >= 0 || name.indexOf("fy27") >= 0) {
        sheet = allSheets[i];
        break;
      }
    }
  }

  if (!sheet) {
    sheet = allSheets[0];
  }
  console.log("Using sheet: " + sheet.getName());

  var usedRange = sheet.getUsedRange();
  if (!usedRange) {
    console.log("Sheet has no data");
    return;
  }

  var lastRow = usedRange.getRowCount();
  console.log("Row count: " + lastRow);
  var dataRange = sheet.getRange("A1:S" + lastRow);
  var values = dataRange.getValues();
  if (!values || values.length === 0) {
    console.log("No values in range");
    return;
  }
  console.log("Got " + values.length + " rows x " + values[0].length + " columns");

  var updated = 0;
  var skipped = 0;

  var STEP_ID_COL = 0;
  var CORP_STATUS_COL = 5;
  var CORP_COMPLETED_COL = 6;
  var FED_STATUS_COL = 9;

  // Build a map of step ID to row index
  var rowMap: { [key: string]: number } = {};
  for (var r = 1; r < values.length; r++) {
    var cellId = String(values[r][STEP_ID_COL]).trim();
    if (cellId) {
      rowMap[cellId] = r;
    }
  }

  // Update Excel cells from bot data
  for (var si = 0; si < data.steps.length; si++) {
    var step = data.steps[si];
    var r = rowMap[step.stepId];
    if (r === undefined) { skipped++; continue; }
    var changed = false;

    var currentCorpStatus = String(values[r][CORP_STATUS_COL]).trim();
    if (step.status && step.status !== currentCorpStatus) {
      sheet.getCell(r, CORP_STATUS_COL).setValue(step.status);
      changed = true;
    }

    if (step.completedDate) {
      var currentDate = String(values[r][CORP_COMPLETED_COL]).trim();
      if (step.completedDate !== currentDate) {
        sheet.getCell(r, CORP_COMPLETED_COL).setValue(step.completedDate);
        changed = true;
      }
    }

    var currentFedStatus = String(values[r][FED_STATUS_COL]).trim();
    if (step.fedStatus && step.fedStatus !== currentFedStatus) {
      sheet.getCell(r, FED_STATUS_COL).setValue(step.fedStatus);
      changed = true;
    }

    if (changed) updated++;
  }

  console.log("Sync complete: " + updated + " steps updated, " + skipped + " not found in sheet");
}

interface BotStep {
  stepId: string;
  status: string;
  fedStatus: string;
  completedDate: string | null;
  lastModifiedBy: string | null;
  lastModifiedDate: string | null;
  description: string | null;
}

interface BotData {
  timestamp: string;
  stepCount: number;
  steps: BotStep[];
}
